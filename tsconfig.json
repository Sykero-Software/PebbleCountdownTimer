{
  "compilerOptions": {
    "target": "ES5",
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2017", "DOM"],
    "rootDir": "src/ts",
    "outDir": "src/pkjs",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "removeComments": false,
    "types": []
  },
  "include": ["src/ts/**/*.ts"]
}
