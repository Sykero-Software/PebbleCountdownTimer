{
  "name": "countdown-timer",
  "author": "Sykerö Software",
  "version": "1.1.8",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": {
    "pebble-clay": "^1.0.4"
  },
  "pebble": {
    "displayName": "Countdown timer",
    "uuid": "6514c531-5e09-470e-8ffb-ce633f721e64",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": ["aplite", "basalt", "diorite", "emery", "flint"],
    "capabilities": [],
    "watchapp": { "watchface": false },
    "messageKeys": ["TimerConfig", "SortOrder", "Request", "AutoReturn", "RunningFirst", "AddTimer", "DeleteTimer", "IdleExitSec", "CfgOpen"],
    "resources": {
      "media": [
        { "type": "bitmap", "menuIcon": true, "name": "MENU_ICON", "file": "images/menuicon.png" }
      ]
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test tests/*.test.js"
  }
}
